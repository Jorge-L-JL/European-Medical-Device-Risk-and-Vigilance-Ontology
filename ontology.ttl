###  http://www.example.org/emdv-o#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :FieldSafetyCorrectiveAction ,
                   :SafetyAlertAction ;
          :correctsIncident :INC-001 ;
          :hasActionType :SafetyAlert ;
          :hasFSCAStatus :Open ;
          :actionDate "2024-02-01"^^xsd:date ;
          :countriesAffected "EU-wide" ;
          :devicesAffected "850" ;
          :eudamedFscaReference "EU-FSCA-2024-000001" ;
          :fscaDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :fscaIdentifier "FSCA-001" ;
          :fscaScope "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Field safety corrective action instance imported from acciones_correctivas.csv."@en ;
          rdfs:label "FSCA-001 - SafetyAlert"@en .


