        <rdfs:label xml:lang="en">intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#isActive">
