    <!-- http://www.example.org/emdv-o#reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#reportDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#riskDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#riskDescription">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#riskIdentifier -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#riskIdentifier">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#riskName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#riskName">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#udiDi -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#udiDi">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique device identifier-device identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">udi di</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdv-o#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device whose operation depends on a source of energy other than that generated by the human body or gravity.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#ActiveImplant -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#ImplantableDevice"/>
        <rdfs:comment xml:lang="en">An implantable medical device whose operation depends on a source of energy.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#CompetentAuthority -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#CompetentAuthority">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A national competent authority responsible for regulatory supervision.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#ContaminationRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the ContaminationRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#Country -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#Country">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A country related to manufacturers, incident reports or external references.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#CriticalRiskIncident -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#CriticalRiskIncident">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.example.org/emdv-o#Incident"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.example.org/emdv-o#associatedWithRisk"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.example.org/emdv-o#Risk"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.example.org/emdv-o#hasSeverity"/>
                                        <owl:hasValue rdf:resource="http://www.example.org/emdv-o#Critical"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:comment xml:lang="en">An inferred incident associated with a risk classified as critical.</rdfs:comment>
        <rdfs:label xml:lang="en">Critical Risk Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the CybersecurityRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#DeviceType -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the technical or regulatory type of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#DeviceWithSeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#DeviceWithSeriousIncident">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.example.org/emdv-o#MedicalDevice"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="http://www.example.org/emdv-o#involvesDevice"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="http://www.example.org/emdv-o#SeriousIncident"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:comment xml:lang="en">An inferred device involved in at least one serious incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Device With Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the DiagnosticRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#FSCAStatus -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#FSCAStatus">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the status of a field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Status</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#FSCAType -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#FSCAType">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the type of field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA Type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#FieldSafetyCorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#correctsIncident"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A field safety corrective action taken to reduce or eliminate risk associated with a medical device incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#IVDRClassC -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#IVDRClassC">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">IVDR class C risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">I V D R Class C</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#IVDRClassD -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#IVDRClassD">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">IVDR class D risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">I V D R Class D</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#IVDRFramework -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#IVDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">In Vitro Diagnostic Medical Device Regulation framework.</rdfs:comment>
        <rdfs:label xml:lang="en">I V D R Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#IVDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#RiskClass"/>
        <rdfs:comment xml:lang="en">A risk class defined under the In Vitro Diagnostic Medical Device Regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">I V D R Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#ImplantableDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device that is both implantable and active.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device intended to be totally or partially introduced into the human body and remain there after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#InSituCorrectionAction -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#InSituCorrectionAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action performed on devices already placed in the field.</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#regulatedUnder"/>
                <owl:hasValue rdf:resource="http://www.example.org/emdv-o#IVDR"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device intended for in vitro examination of specimens derived from the human body.</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#Incident -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#Incident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#associatedWithRisk"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#involvesDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#reportedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A reported event involving a medical device and an associated risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#InfectionRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the InfectionRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#InjuryRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the InjuryRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#InterferenceRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the InterferenceRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MDRClassIII -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MDRClassIII">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">MDR class III risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">M D R Class I I I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MDRClassIIa -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MDRClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">MDR class IIa risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">M D R Class I Ia</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MDRClassIIb -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MDRClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">MDR class IIb risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">M D R Class I Ib</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MDRFramework -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Medical Device Regulation framework.</rdfs:comment>
        <rdfs:label xml:lang="en">M D R Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MDRRiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#RiskClass"/>
        <rdfs:comment xml:lang="en">A risk class defined under the Medical Device Regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">M D R Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the MalfunctionRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#Manufacturer -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">An organization responsible for manufacturing or placing a medical device on the European market.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MaterialRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the MaterialRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MedDeviceCatalogueEntity -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MedDeviceCatalogueEntity">
        <rdfs:comment xml:lang="en">Root class for all entities represented in the European medical device risk and vigilance catalogue.</rdfs:comment>
        <rdfs:label xml:lang="en">Med Device Catalogue Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#MedicalDevice -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#manufacturedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#regulatedUnder"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device registered in the European catalogue under MDR or IVDR regulatory frameworks.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Medical_device"/>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#NearMissIncident -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:comment xml:lang="en">An incident that could have led to harm but did not result in serious consequences.</rdfs:comment>
        <rdfs:label xml:lang="en">Near Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#OpenCorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#OpenCorrectiveAction">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.example.org/emdv-o#hasFSCAStatus"/>
                        <owl:hasValue rdf:resource="http://www.example.org/emdv-o#Open"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">An inferred field safety corrective action whose status is open.</rdfs:comment>
        <rdfs:label xml:lang="en">Open Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#PatientSex -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#PatientSex">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the sex of the affected patient.</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Sex</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#ProbabilityLevel -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#ProbabilityLevel">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the probability level of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Probability Level</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#RadiationRisk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">A risk subclass corresponding to the RadiationRisk risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#RecallAction -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#RecallAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:comment xml:lang="en">A corrective action involving a product recall.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#RegulatoryFramework -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing the applicable European regulatory framework.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#Risk -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#Risk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#hasProbability"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#ProbabilityLevel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/emdv-o#hasSeverity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/emdv-o#SeverityLevel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A safety, performance or clinical risk associated with a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#RiskCategory -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#RiskCategory">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
        <rdfs:comment xml:lang="en">A controlled concept representing a broad category of risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#RiskClass -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#MedDeviceCatalogueEntity"/>
