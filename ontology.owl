<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/emdv-o#"
     xml:base="http://www.example.org/emdv-o"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:emdv-o="http://www.example.org/emdv-o#">
    <owl:Ontology rdf:about="http://www.example.org/emdv-o">
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-26</terms:created>
        <terms:creator xml:lang="en">Jorge Granados</terms:creator>
        <terms:description xml:lang="en">Ontology for representing European medical devices, manufacturers, risks, incidents and field safety corrective actions under MDR and IVDR frameworks.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">European Medical Device Risk and Vigilance Ontology</terms:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument1 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument1"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument2 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument2"/>
    


    <!-- http://www.w3.org/2003/11/swrl#body -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#body"/>
    


    <!-- http://www.w3.org/2003/11/swrl#classPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#classPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#head -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#head"/>
    


    <!-- http://www.w3.org/2003/11/swrl#propertyPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#propertyPredicate"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdv-o#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#affectsDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#DeviceType"/>
        <rdfs:comment xml:lang="en">Relates a risk to the type of medical device affected.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#associatedWithRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#associatedWithRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the risk identified in the report.</rdfs:comment>
        <rdfs:label xml:lang="en">associated with risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#authorizedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#authorizedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to its competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">authorized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#correctsIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#correctsIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to the incident it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">corrects incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasActionType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasActionType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#FSCAType"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to its type.</rdfs:comment>
        <rdfs:label xml:lang="en">has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#DeviceType"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its device type.</rdfs:comment>
        <rdfs:label xml:lang="en">has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasFSCAStatus -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasFSCAStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to its current status.</rdfs:comment>
        <rdfs:label xml:lang="en">has f s c a status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasPatientSex -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasPatientSex">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#PatientSex"/>
        <rdfs:comment xml:lang="en">Relates an incident to the sex of the affected patient.</rdfs:comment>
        <rdfs:label xml:lang="en">has patient sex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasProbability -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasProbability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#ProbabilityLevel"/>
        <rdfs:comment xml:lang="en">Relates a risk to its probability level.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasRiskCategory">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#RiskCategory"/>
        <rdfs:comment xml:lang="en">Relates a risk to its general category.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#hasSeverity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#SeverityLevel"/>
        <rdfs:comment xml:lang="en">Relates a risk to its severity level.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#involvesDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates an incident to the medical device involved in it.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#locatedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#locatedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Country"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to the country where it is located.</rdfs:comment>
        <rdfs:label xml:lang="en">located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#manufacturedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to the manufacturer responsible for it.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#regulatedUnder -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#regulatedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Relates a medical device to the applicable regulatory framework.</rdfs:comment>
        <rdfs:label xml:lang="en">regulated under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the reporting manufacturer or organization.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/emdv-o#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/emdv-o#reportedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/emdv-o#Country"/>
        <rdfs:comment xml:lang="en">Relates an incident to the country where it was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/emdv-o#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#actionDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#authorizationNumber">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authorization number of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#closureDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#closureDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#contactEmail">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Regulatory contact email of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#correctiveActionTaken">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken.</rdfs:comment>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#countriesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#countriesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Countries affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">countries affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#detectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#detectionDate">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#deviceIdentifier -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#deviceIdentifier">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#deviceName">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial or technical name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#devicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Number or description of affected devices.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#eudamedFscaReference -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#eudamedFscaReference">
