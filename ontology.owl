    <!-- http://www.example.org/emdv-o#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#intendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#MedicalDevice"/>
