    <!-- http://www.example.org/emdv-o#manufacturerName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#manufacturerName">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Official name of the manufacturer.</rdfs:comment>
