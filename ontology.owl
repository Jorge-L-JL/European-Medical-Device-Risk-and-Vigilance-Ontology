        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the incident occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#fscaDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#fscaDescription">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">fsca description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#fscaIdentifier -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#fscaIdentifier">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">fsca identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#fscaScope -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#fscaScope">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Scope of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">fsca scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#imdrfCode">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IMDRF code associated with the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">imdrf code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#incidentDescription -->


