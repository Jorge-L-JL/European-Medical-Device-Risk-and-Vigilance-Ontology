        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An in vitro diagnostic device intended to be used by lay persons.</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/emdv-o#SeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/emdv-o#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/emdv-o#Incident"/>
