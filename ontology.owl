        <rdfs:label xml:lang="en">eudamed fsca reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#eudamedIncidentReference -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#eudamedIncidentReference">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">EUDAMED reference for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">eudamed incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#eudamedSrn -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#eudamedSrn">
        <rdfs:domain rdf:resource="http://www.example.org/emdv-o#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
