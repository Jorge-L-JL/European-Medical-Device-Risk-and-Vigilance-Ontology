        <rdfs:label xml:lang="en">eudamed srn</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/emdv-o#eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/emdv-o#eventDate">
