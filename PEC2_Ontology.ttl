@prefix : <http://www.example.org/emdv-o#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .

<http://www.example.org/emdv-o> rdf:type owl:Ontology ;
    dcterms:title "European Medical Device Risk and Vigilance Ontology"@en ;
    dcterms:description "Ontology for representing European medical devices, manufacturers, risks, incidents and field safety corrective actions under MDR and IVDR frameworks."@en ;
    dcterms:creator "Jorge Granados"@en ;
    dcterms:created "2026-04-26"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> .

#################################################################
# Classes
#################################################################

:ActiveDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "Active Device"@en ;
    rdfs:comment "A medical device whose operation depends on a source of energy other than that generated by the human body or gravity."@en .

:ActiveImplant rdf:type owl:Class ;
    rdfs:subClassOf :ImplantableDevice ;
    rdfs:label "Active Implant"@en ;
    rdfs:comment "An implantable medical device whose operation depends on a source of energy."@en .

:CompetentAuthority rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Competent Authority"@en ;
    rdfs:comment "A national competent authority responsible for regulatory supervision."@en .

:ContaminationRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Contamination Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the ContaminationRisk risk type."@en .

:Country rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Country"@en ;
    rdfs:comment "A country related to manufacturers, incident reports or external references."@en .

:CriticalRiskIncident rdf:type owl:Class ;
    rdfs:subClassOf :Incident ;
    rdfs:label "Critical Risk Incident"@en ;
    rdfs:comment "An inferred incident associated with a risk classified as critical."@en .

:CybersecurityRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Cybersecurity Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the CybersecurityRisk risk type."@en .

:DeviceType rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Device Type"@en ;
    rdfs:comment "A controlled concept representing the technical or regulatory type of a medical device."@en .

:DeviceWithSeriousIncident rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "Device With Serious Incident"@en ;
    rdfs:comment "An inferred device involved in at least one serious incident."@en .

:DiagnosticRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Diagnostic Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the DiagnosticRisk risk type."@en .

:FSCAStatus rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "FSCA Status"@en ;
    rdfs:comment "A controlled concept representing the status of a field safety corrective action."@en .

:FSCAType rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "FSCA Type"@en ;
    rdfs:comment "A controlled concept representing the type of field safety corrective action."@en .

:FieldSafetyCorrectiveAction rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Field Safety Corrective Action"@en ;
    rdfs:comment "A field safety corrective action taken to reduce or eliminate risk associated with a medical device incident."@en .

:IVDRClassC rdf:type owl:Class ;
    rdfs:subClassOf :IVDRRiskClass ;
    rdfs:label "I V D R Class C"@en ;
    rdfs:comment "IVDR class C risk classification."@en .

:IVDRClassD rdf:type owl:Class ;
    rdfs:subClassOf :IVDRRiskClass ;
    rdfs:label "I V D R Class D"@en ;
    rdfs:comment "IVDR class D risk classification."@en .

:IVDRFramework rdf:type owl:Class ;
    rdfs:subClassOf :RegulatoryFramework ;
    rdfs:label "I V D R Framework"@en ;
    rdfs:comment "In Vitro Diagnostic Medical Device Regulation framework."@en .

:IVDRRiskClass rdf:type owl:Class ;
    rdfs:subClassOf :RiskClass ;
    rdfs:label "I V D R Risk Class"@en ;
    rdfs:comment "A risk class defined under the In Vitro Diagnostic Medical Device Regulation."@en .

:ImplantableActiveDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "Implantable Active Device"@en ;
    rdfs:comment "A medical device that is both implantable and active."@en .

:ImplantableDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "Implantable Device"@en ;
    rdfs:comment "A medical device intended to be totally or partially introduced into the human body and remain there after the procedure."@en .

:InSituCorrectionAction rdf:type owl:Class ;
    rdfs:subClassOf :FieldSafetyCorrectiveAction ;
    rdfs:label "In Situ Correction Action"@en ;
    rdfs:comment "A corrective action performed on devices already placed in the field."@en .

:InVitroDiagnosticDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "In Vitro Diagnostic Device"@en ;
    rdfs:comment "A medical device intended for in vitro examination of specimens derived from the human body."@en .

:Incident rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Incident"@en ;
    rdfs:comment "A reported event involving a medical device and an associated risk."@en .

:InfectionRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Infection Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the InfectionRisk risk type."@en .

:InjuryRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Injury Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the InjuryRisk risk type."@en .

:InterferenceRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Interference Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the InterferenceRisk risk type."@en .

:MDRClassIII rdf:type owl:Class ;
    rdfs:subClassOf :MDRRiskClass ;
    rdfs:label "M D R Class I I I"@en ;
    rdfs:comment "MDR class III risk classification."@en .

:MDRClassIIa rdf:type owl:Class ;
    rdfs:subClassOf :MDRRiskClass ;
    rdfs:label "M D R Class I Ia"@en ;
    rdfs:comment "MDR class IIa risk classification."@en .

:MDRClassIIb rdf:type owl:Class ;
    rdfs:subClassOf :MDRRiskClass ;
    rdfs:label "M D R Class I Ib"@en ;
    rdfs:comment "MDR class IIb risk classification."@en .

:MDRFramework rdf:type owl:Class ;
    rdfs:subClassOf :RegulatoryFramework ;
    rdfs:label "M D R Framework"@en ;
    rdfs:comment "Medical Device Regulation framework."@en .

:MDRRiskClass rdf:type owl:Class ;
    rdfs:subClassOf :RiskClass ;
    rdfs:label "M D R Risk Class"@en ;
    rdfs:comment "A risk class defined under the Medical Device Regulation."@en .

:MalfunctionRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Malfunction Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the MalfunctionRisk risk type."@en .

:Manufacturer rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Manufacturer"@en ;
    rdfs:comment "An organization responsible for manufacturing or placing a medical device on the European market."@en .

:MaterialRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Material Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the MaterialRisk risk type."@en .

:MedDeviceCatalogueEntity rdf:type owl:Class ;
    rdfs:label "Med Device Catalogue Entity"@en ;
    rdfs:comment "Root class for all entities represented in the European medical device risk and vigilance catalogue."@en .

:MedicalDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Medical Device"@en ;
    rdfs:comment "A medical device registered in the European catalogue under MDR or IVDR regulatory frameworks."@en .

:NearMissIncident rdf:type owl:Class ;
    rdfs:subClassOf :Incident ;
    rdfs:label "Near Miss Incident"@en ;
    rdfs:comment "An incident that could have led to harm but did not result in serious consequences."@en .

:OpenCorrectiveAction rdf:type owl:Class ;
    rdfs:subClassOf :FieldSafetyCorrectiveAction ;
    rdfs:label "Open Corrective Action"@en ;
    rdfs:comment "An inferred field safety corrective action whose status is open."@en .

:PatientSex rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Patient Sex"@en ;
    rdfs:comment "A controlled concept representing the sex of the affected patient."@en .

:ProbabilityLevel rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Probability Level"@en ;
    rdfs:comment "A controlled concept representing the probability level of a risk."@en .

:RadiationRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Radiation Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the RadiationRisk risk type."@en .

:RecallAction rdf:type owl:Class ;
    rdfs:subClassOf :FieldSafetyCorrectiveAction ;
    rdfs:label "Recall Action"@en ;
    rdfs:comment "A corrective action involving a product recall."@en .

:RegulatoryFramework rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Regulatory Framework"@en ;
    rdfs:comment "A controlled concept representing the applicable European regulatory framework."@en .

:Risk rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Risk"@en ;
    rdfs:comment "A safety, performance or clinical risk associated with a medical device."@en .

:RiskCategory rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Risk Category"@en ;
    rdfs:comment "A controlled concept representing a broad category of risk."@en .

:RiskClass rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Risk Class"@en ;
    rdfs:comment "A controlled concept representing a regulatory risk class under MDR or IVDR."@en .

:SafetyAlertAction rdf:type owl:Class ;
    rdfs:subClassOf :FieldSafetyCorrectiveAction ;
    rdfs:label "Safety Alert Action"@en ;
    rdfs:comment "A corrective action communicated as a safety alert."@en .

:SelfTestDevice rdf:type owl:Class ;
    rdfs:subClassOf :InVitroDiagnosticDevice ;
    rdfs:label "Self Test Device"@en ;
    rdfs:comment "An in vitro diagnostic device intended to be used by lay persons."@en .

:SeriousIncident rdf:type owl:Class ;
    rdfs:subClassOf :Incident ;
    rdfs:label "Serious Incident"@en ;
    rdfs:comment "An incident that caused or could have caused serious deterioration of health or death."@en .

:SeverityLevel rdf:type owl:Class ;
    rdfs:subClassOf :MedDeviceCatalogueEntity ;
    rdfs:label "Severity Level"@en ;
    rdfs:comment "A controlled concept representing the severity level of a risk."@en .

:SingleUseDevice rdf:type owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label "Single Use Device"@en ;
    rdfs:comment "A medical device intended to be used once for a single patient."@en .

:SoftwareRisk rdf:type owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label "Software Risk"@en ;
    rdfs:comment "A risk subclass corresponding to the SoftwareRisk risk type."@en .

:UserNoticeAction rdf:type owl:Class ;
    rdfs:subClassOf :FieldSafetyCorrectiveAction ;
    rdfs:label "User Notice Action"@en ;
    rdfs:comment "A corrective action communicated as a user notice."@en .

:ImplantableActiveDevice rdfs:subClassOf :ImplantableDevice , :ActiveDevice .
:ActiveImplant rdfs:subClassOf :ActiveDevice .

#################################################################
# Object properties
#################################################################

:manufacturedBy rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range :Manufacturer ;
    rdfs:label "manufactured by"@en ;
    rdfs:comment "Relates a medical device to the manufacturer responsible for it."@en .

:hasDeviceType rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range :DeviceType ;
    rdfs:label "has device type"@en ;
    rdfs:comment "Relates a medical device to its device type."@en .

:hasRiskClass rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range :RiskClass ;
    rdfs:label "has risk class"@en ;
    rdfs:comment "Relates a medical device to its regulatory risk class."@en .

:regulatedUnder rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range :RegulatoryFramework ;
    rdfs:label "regulated under"@en ;
    rdfs:comment "Relates a medical device to the applicable regulatory framework."@en .

:locatedInCountry rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range :Country ;
    rdfs:label "located in country"@en ;
    rdfs:comment "Relates a manufacturer to the country where it is located."@en .

:authorizedBy rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range :CompetentAuthority ;
    rdfs:label "authorized by"@en ;
    rdfs:comment "Relates a manufacturer to its competent authority."@en .

:involvesDevice rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range :MedicalDevice ;
    rdfs:label "involves device"@en ;
    rdfs:comment "Relates an incident to the medical device involved in it."@en .

:associatedWithRisk rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range :Risk ;
    rdfs:label "associated with risk"@en ;
    rdfs:comment "Relates an incident to the risk identified in the report."@en .

:reportedBy rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range :Manufacturer ;
    rdfs:label "reported by"@en ;
    rdfs:comment "Relates an incident to the reporting manufacturer or organization."@en .

:reportedInCountry rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range :Country ;
    rdfs:label "reported in country"@en ;
    rdfs:comment "Relates an incident to the country where it was reported."@en .

:hasPatientSex rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range :PatientSex ;
    rdfs:label "has patient sex"@en ;
    rdfs:comment "Relates an incident to the sex of the affected patient."@en .

:hasSeverity rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Risk ;
    rdfs:range :SeverityLevel ;
    rdfs:label "has severity"@en ;
    rdfs:comment "Relates a risk to its severity level."@en .

:hasProbability rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Risk ;
    rdfs:range :ProbabilityLevel ;
    rdfs:label "has probability"@en ;
    rdfs:comment "Relates a risk to its probability level."@en .

:hasRiskCategory rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Risk ;
    rdfs:range :RiskCategory ;
    rdfs:label "has risk category"@en ;
    rdfs:comment "Relates a risk to its general category."@en .

:affectsDeviceType rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Risk ;
    rdfs:range :DeviceType ;
    rdfs:label "affects device type"@en ;
    rdfs:comment "Relates a risk to the type of medical device affected."@en .

:correctsIncident rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range :Incident ;
    rdfs:label "corrects incident"@en ;
    rdfs:comment "Relates a field safety corrective action to the incident it addresses."@en .

:hasActionType rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range :FSCAType ;
    rdfs:label "has action type"@en ;
    rdfs:comment "Relates a field safety corrective action to its type."@en .

:hasFSCAStatus rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range :FSCAStatus ;
    rdfs:label "has f s c a status"@en ;
    rdfs:comment "Relates a field safety corrective action to its current status."@en .

#################################################################
# Data properties
#################################################################

:deviceIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:string ;
    rdfs:label "device identifier"@en ;
    rdfs:comment "Identifier of the medical device."@en .

:deviceName rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:string ;
    rdfs:label "device name"@en ;
    rdfs:comment "Commercial or technical name of the medical device."@en .

:udiDi rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:string ;
    rdfs:label "udi di"@en ;
    rdfs:comment "Unique device identifier-device identifier."@en .

:intendedPurpose rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:string ;
    rdfs:label "intended purpose"@en ;
    rdfs:comment "Intended medical purpose of the device."@en .

:isIVD rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:boolean ;
    rdfs:label "is i v d"@en ;
    rdfs:comment "Indicates whether the device is an in vitro diagnostic device."@en .

:isImplantable rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:boolean ;
    rdfs:label "is implantable"@en ;
    rdfs:comment "Indicates whether the device is implantable."@en .

:isActive rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:boolean ;
    rdfs:label "is active"@en ;
    rdfs:comment "Indicates whether the device is active."@en .

:isReusable rdf:type owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range xsd:boolean ;
    rdfs:label "is reusable"@en ;
    rdfs:comment "Indicates whether the device is reusable."@en .

:manufacturerIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range xsd:string ;
    rdfs:label "manufacturer identifier"@en ;
    rdfs:comment "Identifier of the manufacturer."@en .

:manufacturerName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range xsd:string ;
    rdfs:label "manufacturer name"@en ;
    rdfs:comment "Official name of the manufacturer."@en .

:authorizationNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range xsd:string ;
    rdfs:label "authorization number"@en ;
    rdfs:comment "Authorization number of the manufacturer."@en .

:contactEmail rdf:type owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range xsd:string ;
    rdfs:label "contact email"@en ;
    rdfs:comment "Regulatory contact email of the manufacturer."@en .

:eudamedSrn rdf:type owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range xsd:string ;
    rdfs:label "eudamed srn"@en ;
    rdfs:comment "EUDAMED single registration number of the manufacturer."@en .

:riskIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range xsd:string ;
    rdfs:label "risk identifier"@en ;
    rdfs:comment "Identifier of the risk."@en .

:imdrfCode rdf:type owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range xsd:string ;
    rdfs:label "imdrf code"@en ;
    rdfs:comment "IMDRF code associated with the risk."@en .

:riskName rdf:type owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range xsd:string ;
    rdfs:label "risk name"@en ;
    rdfs:comment "Name of the risk."@en .

:riskDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range xsd:string ;
    rdfs:label "risk description"@en ;
    rdfs:comment "Textual description of the risk."@en .

:incidentIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:string ;
    rdfs:label "incident identifier"@en ;
    rdfs:comment "Identifier of the incident."@en .

:reportDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:date ;
    rdfs:label "report date"@en ;
    rdfs:comment "Date on which the incident was reported."@en .

:detectionDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:date ;
    rdfs:label "detection date"@en ;
    rdfs:comment "Date on which the incident was detected."@en .

:eventDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:date ;
    rdfs:label "event date"@en ;
    rdfs:comment "Date on which the incident occurred."@en .

:incidentOutcome rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:string ;
    rdfs:label "incident outcome"@en ;
    rdfs:comment "Outcome of the incident."@en .

:patientAge rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:decimal ;
    rdfs:label "patient age"@en ;
    rdfs:comment "Age of the affected patient."@en .

:eudamedIncidentReference rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:string ;
    rdfs:label "eudamed incident reference"@en ;
    rdfs:comment "EUDAMED reference for the incident."@en .

:incidentDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:string ;
    rdfs:label "incident description"@en ;
    rdfs:comment "Textual description of the incident."@en .

:correctiveActionTaken rdf:type owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range xsd:boolean ;
    rdfs:label "corrective action taken"@en ;
    rdfs:comment "Indicates whether a corrective action was taken."@en .

:fscaIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "fsca identifier"@en ;
    rdfs:comment "Identifier of the field safety corrective action."@en .

:actionDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:date ;
    rdfs:label "action date"@en ;
    rdfs:comment "Date on which the corrective action was initiated."@en .

:closureDate rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:date ;
    rdfs:label "closure date"@en ;
    rdfs:comment "Date on which the corrective action was closed."@en .

:fscaScope rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "fsca scope"@en ;
    rdfs:comment "Scope of the field safety corrective action."@en .

:devicesAffected rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "devices affected"@en ;
    rdfs:comment "Number or description of affected devices."@en .

:countriesAffected rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "countries affected"@en ;
    rdfs:comment "Countries affected by the corrective action."@en .

:fscaDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "fsca description"@en ;
    rdfs:comment "Textual description of the field safety corrective action."@en .

:eudamedFscaReference rdf:type owl:DatatypeProperty ;
    rdfs:domain :FieldSafetyCorrectiveAction ;
    rdfs:range xsd:string ;
    rdfs:label "eudamed fsca reference"@en ;
    rdfs:comment "EUDAMED reference for the field safety corrective action."@en .

#################################################################
# OWL restrictions
#################################################################

:MedicalDevice rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :manufacturedBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Manufacturer
] .

:MedicalDevice rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasRiskClass ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :RiskClass
] .

:MedicalDevice rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :regulatedUnder ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :RegulatoryFramework
] .

:Incident rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :involvesDevice ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :MedicalDevice
] .

:Incident rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :associatedWithRisk ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Risk
] .

:Incident rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :reportedBy ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Manufacturer
] .

:FieldSafetyCorrectiveAction rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :correctsIncident ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :Incident
] .

:Risk rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasSeverity ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :SeverityLevel
] .

:Risk rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasProbability ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass :ProbabilityLevel
] .

:InVitroDiagnosticDevice rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :regulatedUnder ;
    owl:hasValue :IVDR
] .

