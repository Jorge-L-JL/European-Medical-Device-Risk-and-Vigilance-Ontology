#################################################################
# SWRL rules
#################################################################

<urn:swrl#i> rdf:type swrl:Variable .
<urn:swrl#r> rdf:type swrl:Variable .
<urn:swrl#d> rdf:type swrl:Variable .
<urn:swrl#f> rdf:type swrl:Variable .

:CriticalRiskIncidentRule rdf:type swrl:Imp ;
    rdfs:label "Critical risk incident rule"@en ;
    swrl:body (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :Incident ; swrl:argument1 <urn:swrl#i> ]
        [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate :associatedWithRisk ; swrl:argument1 <urn:swrl#i> ; swrl:argument2 <urn:swrl#r> ]
        [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate :hasSeverity ; swrl:argument1 <urn:swrl#r> ; swrl:argument2 :Critical ]
    ) ;
    swrl:head (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :CriticalRiskIncident ; swrl:argument1 <urn:swrl#i> ]
    ) .

:DeviceWithSeriousIncidentRule rdf:type swrl:Imp ;
    rdfs:label "Device with serious incident rule"@en ;
    swrl:body (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :MedicalDevice ; swrl:argument1 <urn:swrl#d> ]
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :SeriousIncident ; swrl:argument1 <urn:swrl#i> ]
        [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate :involvesDevice ; swrl:argument1 <urn:swrl#i> ; swrl:argument2 <urn:swrl#d> ]
    ) ;
    swrl:head (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :DeviceWithSeriousIncident ; swrl:argument1 <urn:swrl#d> ]
    ) .

:OpenCorrectiveActionRule rdf:type swrl:Imp ;
    rdfs:label "Open corrective action rule"@en ;
    swrl:body (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :FieldSafetyCorrectiveAction ; swrl:argument1 <urn:swrl#f> ]
        [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate :hasFSCAStatus ; swrl:argument1 <urn:swrl#f> ; swrl:argument2 :Open ]
    ) ;
    swrl:head (
        [ rdf:type swrl:ClassAtom ; swrl:classPredicate :OpenCorrectiveAction ; swrl:argument1 <urn:swrl#f> ]
    ) .
